# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env (gitignored) and fill in real values for local dev.
# On Railway, set these as environment variables in the project dashboard.
# NEVER commit .env or application-local.yml — both are in .gitignore.

# ── Database ───────────────────────────────────────────────────────────────────
# Matches the docker-compose.yml postgres service defaults.
# On Railway, copy the values from the PostgreSQL service's "Variables" tab.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=support_agent
DB_USER=support_agent
DB_PASSWORD=support_agent

# ── AI API Keys ────────────────────────────────────────────────────────────────
# Only required when APP_AI_MOCK_ENABLED=false.
# Get your Anthropic key at: https://console.anthropic.com
# Get your OpenAI key at:    https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Mock Mode ──────────────────────────────────────────────────────────────────
# true  → MockRagService is active; no API keys needed (safe default)
# false → ClaudeRagService is active; requires both keys above
APP_AI_MOCK_ENABLED=true

# ── Spring Boot Admin ──────────────────────────────────────────────────────────
# ADMIN_HOST: hostname of the admin server container.
#   local dev (admin in Docker): localhost
#   full Docker Compose stack:   admin-server  (the docker-compose service name)
#   Railway:                     your Railway admin service internal hostname
ADMIN_HOST=localhost
ADMIN_PASSWORD=changeme

# ── App base URL (Spring Boot Admin callback) ──────────────────────────────────
# The admin SERVER calls this URL to poll our actuator health endpoint.
# It must be reachable FROM the admin server container, not from your browser.
#
# Running the app locally, admin server in Docker:
APP_BASE_URL=http://host.docker.internal:8080
#
# Full Docker Compose stack (uncomment and remove the line above):
# APP_BASE_URL=http://app:8080
#
# Railway deployment (uncomment and remove the line above):
# APP_BASE_URL=https://your-app-name.up.railway.app
